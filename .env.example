# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit your real key.

GEMINI_API_KEY=paste-your-gemini-key-here

# Optional: which Gemini model to use for explanations.
# gemini-2.5-flash  → fast, generous free tier (recommended)
# gemini-2.5-pro    → smarter but slower and stricter rate limits
GEMINI_MODEL=gemini-2.5-flash
