# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit your real key.

DEEPSEEK_API_KEY=paste-your-deepseek-key-here

# Which DeepSeek model to use for explanations and chat.
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional keys for LLM evaluation benchmarks.
# Add only the providers you actually plan to run.
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
ANTHROPIC_API_KEY=
COHERE_API_KEY=
OLLAMA_API_KEY=
